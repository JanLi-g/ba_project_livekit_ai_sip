# LiveKit
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=YOUR_LIVEKIT_API_KEY_HERE
LIVEKIT_API_SECRET=YOUR_LIVEKIT_API_SECRET_HERE
LIVEKIT_KEYS=YOUR_LIVEKIT_API_KEY_HERE:YOUR_LIVEKIT_API_SECRET_HERE

# OpenAI / LLM
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# SIP Provider
SIP_PROVIDER_DOMAIN=sip.plusnet.de
SIP_PROVIDER_USERNAME=YOUR_SIP_USERNAME_HERE
SIP_PROVIDER_PASSWORD=YOUR_SIP_PASSWORD_HERE
SIP_PROVIDER_AUTH_USERNAME=YOUR_SIP_AUTH_USERNAME_HERE
SIP_DID_NUMBER=+49XXXXXXXXXXX

# Runtime
REDIS_HOST=redis
REDIS_PORT=6379
LOG_LEVEL=info

